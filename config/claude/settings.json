{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh issue view:*)"
    ],
    "deny": [
      "Bash(curl:*)",
      "Bash(git pull:*)",
      "Bash(git rebase:*)",
      "Bash(gh release create:*)"
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "handbook@cc-handbook": true,
    "handbook-extras@cc-handbook": true,
    "code-review@claude-plugins-official": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "cc-handbook": {
      "source": {
        "source": "github",
        "repo": "nikiforovall/claude-code-rules"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  }
}
